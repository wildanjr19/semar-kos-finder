# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.production and fill in your actual values
# Used by: docker compose --profile production
# Services: web (3002)
# =============================================================================

# =============================================================================
# GOOGLE MAPS CONFIGURATION (Required)
# =============================================================================
# Get API key from: https://developers.google.com/maps/documentation/javascript/get-api-key
# Required APIs: Maps JavaScript API, Routes API, Geocoding API
GOOGLE_MAPS_API_KEY=replace_me

# =============================================================================
# NEXT.JS CONFIGURATION
# =============================================================================
# Disable Next.js telemetry (set to 1 to disable)
NEXT_TELEMETRY_DISABLED=1

# Node environment (production enables optimizations)
NODE_ENV=production

# =============================================================================
# BACKEND CONFIGURATION (Optional - uncomment if using backend in production)
# =============================================================================
# Internal URL for backend communication (service name from compose.yaml)
# API_INTERNAL_URL=http://backend_prod:8000

# MongoDB connection string (internal Docker network)
# MONGO_URL=mongodb://mongodb:27017/semar_kos

# JWT Configuration
# Generate a random secret: openssl rand -hex 32
# JWT_SECRET=your_random_jwt_secret_key_here_minimum_32_characters
# JWT_EXPIRE_MINUTES=60

# Admin Authentication
# ADMIN_USERNAME=admin
# Generate bcrypt hash for password:
# docker compose --profile production run --rm backend_prod uv run python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
# ADMIN_PASSWORD_BCRYPT=$2b$12$EXAMPLE_HASH_REPLACE_WITH_REAL_BCRYPT_HASH_HERE
