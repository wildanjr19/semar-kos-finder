# =============================================================================
# ROOT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# Used by: Python scripts in /src (run directly on host, not containerized)
#
# For Docker environments, see:
#   - .env.development (4-container setup: frontend, admin, backend, mongodb)
#   - .env.production (production build)
#   - .env.staging (staging build)
# =============================================================================

# -----------------------------------------------------------------------------
# Google Maps API
# -----------------------------------------------------------------------------
# Required for: Geocoding, Routes API (directions)
# Get API key from: https://developers.google.com/maps/documentation/javascript/get-api-key
# Required APIs: Maps JavaScript API, Routes API, Geocoding API
GMAPS_API_KEY=your_google_maps_api_key_here

# Alternative name used by Next.js (either one works)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# -----------------------------------------------------------------------------
# Next.js Public Variables (for client-side usage)
# -----------------------------------------------------------------------------
# If you need Google Maps on the client, set this:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
