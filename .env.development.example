# =============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.development and fill in your actual values
# Used by: docker compose --profile development
# Services: frontend (3000), admin (3001), backend (8000), mongodb
# =============================================================================

# =============================================================================
# GOOGLE MAPS CONFIGURATION (Required)
# =============================================================================
# Get API key from: https://developers.google.com/maps/documentation/javascript/get-api-key
# Required APIs: Maps JavaScript API, Routes API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================================================
# BACKEND CONFIGURATION (Required)
# =============================================================================
# Internal URL for backend communication (service name from compose.yaml)
API_INTERNAL_URL=http://backend_dev:8000

# MongoDB connection string (internal Docker network)
MONGO_URL=mongodb://mongodb:27017/semar_kos

# JWT Configuration
# Generate a random secret: openssl rand -hex 32
JWT_SECRET=your_random_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRE_MINUTES=60

# Admin Authentication
ADMIN_USERNAME=admin
# Generate bcrypt hash for password:
# docker compose --profile development run --rm backend_dev uv run python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_PASSWORD_BCRYPT=$2b$12$EXAMPLE_HASH_REPLACE_WITH_REAL_BCRYPT_HASH_HERE

# =============================================================================
# E2E TEST CONFIGURATION (Optional)
# =============================================================================
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=admin123
E2E_BACKEND_URL=http://backend_dev:8000

# =============================================================================
# NODE.JS CONFIGURATION (Auto-set by Docker)
# =============================================================================
# These are set automatically in compose.yaml, no need to add:
# NODE_ENV=development
# CHOKIDAR_USEPOLLING=1
# WATCHPACK_POLLING=true
# NEXT_TELEMETRY_DISABLED=1
